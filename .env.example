# Include in .env & .env.test
ENV_NAME=###
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=###
OPENROUTER_API_KEY=###
# Include in .env.test
E2E_USERNAME_ID=###
E2E_USERNAME=###
E2E_PASSWORD=###
# Machine-auth import endpoint (POST /api/import) — server-side only, set in Production
IMPORT_API_KEY=###            # random secret; generate with: openssl rand -hex 32
IMPORT_USER_ID=###            # UUID of the import target account (Supabase Auth → Users)
SUPABASE_SERVICE_ROLE_KEY=### # service-role key; bypasses RLS, never expose client-side